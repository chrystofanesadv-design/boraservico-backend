NODE_ENV=production
PORT=3000

# Core production requirements
JWT_SECRET=replace_with_strong_secret_32_chars_min
REFRESH_TOKEN_SECRET=replace_with_different_strong_refresh_secret_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://usuario:senha@host:5432/boraservico
CORS_ORIGIN=https://seu-app.com,https://boraservico-backend.onrender.com
RENDER_EXTERNAL_URL=https://boraservico-backend.onrender.com

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Compatibility with old deployments only. Keep empty when canonical var is set.
MP_ACCESS_TOKEN=

# Pagar.me
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_RECIPIENT_ID=

# Payments
PLATFORM_COMMISSION_RATE=0.12
PUBLIC_API_URL=https://boraservico-backend.onrender.com
PAYMENT_SUCCESS_URL=
PAYMENT_FAILURE_URL=
PAYMENT_PENDING_URL=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# AI providers
AI_PROVIDER=auto
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Runtime
FCM_ENABLED=true
REALTIME_ENABLED=true
UPLOAD_PUBLIC_URL=https://boraservico-backend.onrender.com/uploads
PROOF_STORAGE_PROVIDER=local-private
PROOF_STORAGE_DIR=
STORAGE_CDN_BASE_URL=
