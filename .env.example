NODE_ENV=development
PORT=3000

# Core
JWT_SECRET=change_me_dev_secret
REFRESH_TOKEN_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/boraservico
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Backward compatibility only. Prefer MERCADO_PAGO_ACCESS_TOKEN.
MP_ACCESS_TOKEN=

# Pagar.me
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_RECIPIENT_ID=
PAGARME_PLATFORM_RECIPIENT_ID=
PAGARME_DEFAULT_RECIPIENT_ID=

# Payments
PLATFORM_COMMISSION_RATE=0.10
PUBLIC_API_URL=http://localhost:3000
PAYMENT_SUCCESS_URL=
PAYMENT_FAILURE_URL=
PAYMENT_PENDING_URL=
MERCADO_PAGO_MARKETPLACE_FEE_ENABLED=false

# Google Maps
GOOGLE_MAPS_API_KEY=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# AI providers
AI_PROVIDER=auto
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional runtime flags
FCM_ENABLED=false
REALTIME_ENABLED=true
UPLOAD_PUBLIC_URL=http://localhost:3000/uploads
PROOF_STORAGE_PROVIDER=local-private
PROOF_STORAGE_DIR=
STORAGE_CDN_BASE_URL=
STORAGE_SIGNED_URL_TTL_SECONDS=900
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
