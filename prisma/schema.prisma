generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS convertidos para String
// ============================================

// UserRole: CLIENT, PROFESSIONAL, ADMIN
// ServiceStatus: CREATED, MATCHING, ACCEPTED, IN_PROGRESS, CHECKED_IN, CHECKED_OUT, COMPLETED, CANCELED, CANCELLED, DISPUTED
// EscrowStatus: HELD, RELEASED, REFUNDED
// DisputeStatus: OPEN, CLIENT, PROFESSIONAL, RESOLVED
// TrackingEventStatus: WAITING, CHECKED_IN, IN_PROGRESS, CHECKED_OUT, COMPLETED, CANCELLED
// OperationalTimelineEventType: CREATED, MATCHING_STARTED, PROFESSIONAL_ACCEPTED, PROFESSIONAL_ON_THE_WAY, CHECKED_IN, IN_PROGRESS, CHECKED_OUT, PROOF_UPLOADED, COMPLETED, PAYMENT_RELEASED, CANCELLED, DISPUTE_OPENED, RATING_REQUESTED
// TimelineEventState: COMPLETE, CURRENT, UPCOMING, ALERT
// WalletTransactionType: CREDIT, DEBIT, ESCROW_HOLD, ESCROW_RELEASE, ESCROW_REFUND, PAYMENT_RELEASE, REFERRAL_BONUS, PIX_WITHDRAWAL, ADJUSTMENT
// WalletTransactionStatus: PENDING, COMPLETED, FAILED, CANCELLED
// WalletTransactionSource: ORDER, PAYMENT, ESCROW, REFERRAL, PIX, MANUAL, SYSTEM
// ReferralStatus: PHASE_1, PHASE_2, COMPLETED, CANCELLED
// ProofVisibility: PRIVATE, ORDER_PARTICIPANTS, SUPPORT, PUBLIC
// ChatSenderRole: CLIENT, PROFESSIONAL, SYSTEM, ADMIN
// PaymentProvider: MERCADO_PAGO, PAGARME, PIX, STRIPE, MANUAL, MOCK
// PaymentStatus: PENDING, AUTHORIZED, PAID, ESCROW_HELD, RELEASED, REFUNDED, PARTIAL_REFUND, SPLIT_DONE, CANCELED, FAILED

// ============================================
// MODELOS
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("CLIENT")
  createdAt DateTime @default(now())

  /// 🔥 OBRIGATÓRIO PARA PUSH NOTIFICATION (FCM)
  fcmToken  String?

  createdOrders     ServiceOrder[] @relation("ClientOrders")
  acceptedOrders    ServiceOrder[] @relation("ProfessionalOrders")
  requestForQuotes  RequestForQuote[] @relation("ClientRequestForQuotes")

  wallet            Wallet?
  trackingEvents    TrackingEvent[] @relation("TrackingActor")
  walletTransactions WalletTransaction[]
  proofUploads      ProofUpload[]
  reviewsWritten    Review[] @relation("ReviewsWritten")
  reviewsReceived   Review[] @relation("ReviewsReceived")
  referralsMade     Referral[] @relation("ReferralReferrer")
  referralsReceived Referral[] @relation("ReferralReferred")
  reputationProfile ReputationProfile?
  paymentRecipients PaymentRecipient[]
}

model ServiceOrder {
  id              String   @id @default(uuid())

  clientId        String
  client          User     @relation("ClientOrders", fields: [clientId], references: [id])

  professionalId  String?
  professional    User?    @relation("ProfessionalOrders", fields: [professionalId], references: [id])

  status          String   @default("CREATED")

  category        String?
  address         String?
  title           String
  description     String
  price           Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  acceptedAt      DateTime?
  startedAt       DateTime?
  checkInAt       DateTime?
  checkOutAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  escrow          Escrow?
  dispute         Dispute?
  trackingEvents TrackingEvent[]
  timelineEvents OperationalTimelineEvent[]
  walletTransactions WalletTransaction[]
  proofUploads   ProofUpload[]
  chatMessages   ChatMessage[]
  reviews        Review[]
  payments       Payment[]
  acceptedRequestForQuote RequestForQuote? @relation("RequestAcceptedOrder")
  acceptedNegotiation     Negotiation?     @relation("NegotiationAcceptedOrder")

  @@index([clientId])
  @@index([professionalId])
  @@index([status])
  @@index([category])
}

model RequestForQuote {
  id              String   @id @default(uuid())
  clientId        String
  client          User     @relation("ClientRequestForQuotes", fields: [clientId], references: [id])
  acceptedOrderId String?  @unique
  acceptedOrder   ServiceOrder? @relation("RequestAcceptedOrder", fields: [acceptedOrderId], references: [id])

  status          String   @default("OPEN")
  title           String
  description     String
  category        String?
  address         String?
  urgency         String?
  observations    String?
  photos          String?
  aiBriefing      String?
  aiQuestions     String?
  aiWarnings      String?
  metadata        String?

  negotiations    Negotiation[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId, createdAt])
  @@index([status])
  @@index([category])
}

model Negotiation {
  id              String   @id @default(uuid())
  requestId       String
  request         RequestForQuote @relation(fields: [requestId], references: [id], onDelete: Cascade)
  acceptedOrderId String?  @unique
  acceptedOrder   ServiceOrder? @relation("NegotiationAcceptedOrder", fields: [acceptedOrderId], references: [id])

  clientId        String
  professionalId  String
  professionalName String
  status          String   @default("OPEN")
  rating          Float?
  distanceKm      Float?
  responseMinutes Int?
  score           Float?
  metadata        String?

  quotes          Quote[]
  counterOffers   CounterOffer[]
  finalOffers     FinalOffer[]
  events          NegotiationEvent[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([requestId, professionalId])
  @@index([requestId, status])
  @@index([clientId, status])
  @@index([professionalId, status])
}

model Quote {
  id              String   @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  professionalId  String
  amount          Float
  deadline        String?
  notes           String?
  includes        String?
  excludes        String?
  materialIncluded Boolean @default(false)
  etaMinutes      Int?
  createdAt       DateTime @default(now())

  @@index([negotiationId, createdAt])
  @@index([professionalId, createdAt])
}

model CounterOffer {
  id              String   @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  clientId        String
  amount          Float
  message         String?
  createdAt       DateTime @default(now())

  @@index([negotiationId, createdAt])
  @@index([clientId, createdAt])
}

model FinalOffer {
  id              String   @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  professionalId  String
  amount          Float
  deadline        String?
  message         String?
  createdAt       DateTime @default(now())

  @@index([negotiationId, createdAt])
  @@index([professionalId, createdAt])
}

model NegotiationEvent {
  id              String   @id @default(uuid())
  negotiationId   String
  negotiation     Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  actorId         String?
  actorRole       String   @default("SYSTEM")
  type            String
  message         String
  metadata        String?
  createdAt       DateTime @default(now())

  @@index([negotiationId, createdAt])
  @@index([type])
}

model Wallet {
  id               String   @id @default(uuid())
  userId           String   @unique
  balance          Float    @default(0)
  escrowBalance    Float    @default(0)
  availableBalance Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id])
}

model Escrow {
  id              String   @id @default(uuid())

  serviceOrderId  String   @unique
  serviceOrder     ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  clientId        String
  amount          Float
  status          String   @default("HELD")

  createdAt       DateTime @default(now())
  releasedAt      DateTime?
}

model Dispute {
  id              String   @id @default(uuid())

  serviceOrderId  String   @unique
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id])

  clientId        String
  professionalId  String?

  reason          String
  status          String   @default("OPEN")

  resolution      String?
  aiScore         Float?
  aiDecision      String?
  aiReason        String?
  aiRiskLevel     String?
  aiReleasePayment Boolean @default(false)
  aiBlockPayment   Boolean @default(false)
  aiSendToAdmin    Boolean @default(false)
  adminReviewRequired Boolean @default(false)
  aiEvidence      String?
  automationApplied String?

  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  @@index([aiRiskLevel])
  @@index([adminReviewRequired])
}

model TrackingEvent {
  id        String   @id @default(uuid())
  orderId   String
  order     ServiceOrder @relation(fields: [orderId], references: [id])
  lat       Float
  lng       Float
  actorId   String?
  actor     User?    @relation("TrackingActor", fields: [actorId], references: [id], onDelete: SetNull)
  status    String
  timestamp DateTime @default(now())
  metadata  String?

  @@index([orderId, timestamp])
  @@index([actorId])
}

model OperationalTimelineEvent {
  id          String   @id @default(uuid())
  orderId     String
  order       ServiceOrder @relation(fields: [orderId], references: [id])
  type        String
  title       String
  description String?
  state       String   @default("CURRENT")
  timestamp   DateTime @default(now())
  metadata    String?

  @@index([orderId, timestamp])
  @@index([type])
}

model WalletTransaction {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  orderId         String?
  order           ServiceOrder? @relation(fields: [orderId], references: [id])
  type            String
  amount          Float
  status          String   @default("COMPLETED")
  source          String   @default("SYSTEM")
  metadata        String?
  timestamp       DateTime @default(now())
  referralBonus   ReferralBonus?

  @@index([userId, timestamp])
  @@index([orderId])
  @@index([type])
  @@index([source])
}

model Referral {
  id              String   @id @default(uuid())
  referrerId      String
  referrer        User     @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referredUserId  String
  referredUser    User     @relation("ReferralReferred", fields: [referredUserId], references: [id])
  status          String   @default("PHASE_1")

  phase1StartAt   DateTime @default(now())
  phase1EndAt     DateTime
  phase1Percent   Float    @default(0.05)
  phase1Limit     Float    @default(300)
  phase1Earned    Float    @default(0)

  phase2StartAt   DateTime?
  phase2EndAt     DateTime?
  phase2Percent   Float    @default(0.025)
  phase2Limit     Float    @default(200)
  phase2Earned    Float    @default(0)

  totalLimit      Float    @default(500)
  totalEarned     Float    @default(0)
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bonuses         ReferralBonus[]

  @@unique([referrerId, referredUserId])
  @@index([referrerId, status])
  @@index([referredUserId, status])
}

model ReferralBonus {
  id                  String             @id @default(uuid())
  referralId          String
  referral            Referral           @relation(fields: [referralId], references: [id])
  referrerId          String
  referredUserId      String
  orderId             String?
  idempotencyKey      String?            @unique
  serviceValue        Float
  phase               Int
  percentage          Float
  bonusAmount         Float
  withdrawable        Boolean            @default(true)
  walletTransactionId String?            @unique
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id])
  createdAt           DateTime           @default(now())

  @@index([referralId])
  @@index([referrerId])
  @@index([orderId])
  @@index([idempotencyKey])
}

model ProofUpload {
  id          String   @id @default(uuid())
  orderId     String
  order       ServiceOrder @relation(fields: [orderId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  fileUrl     String
  storageKey  String
  visibility  String   @default("ORDER_PARTICIPANTS")
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([userId])
}

model ChatMessage {
  id         String   @id @default(uuid())
  orderId    String
  order      ServiceOrder @relation(fields: [orderId], references: [id])
  senderId   String
  senderRole String   @default("SYSTEM")
  message    String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([senderId])
}

model ReputationProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])
  averageRating     Float    @default(5)
  totalReviews      Int      @default(0)
  completedServices Int      @default(0)
  cancelledServices Int      @default(0)
  responseTimeScore Float    @default(100)
  reliabilityScore  Float    @default(100)
  reputationScore   Float    @default(100)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Review {
  id         String       @id @default(uuid())
  orderId    String
  order      ServiceOrder @relation(fields: [orderId], references: [id])
  reviewerId String
  reviewer   User         @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  reviewedId String
  reviewed   User         @relation("ReviewsReceived", fields: [reviewedId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime     @default(now())

  @@unique([orderId, reviewerId, reviewedId])
  @@index([reviewedId, createdAt])
}

model Payment {
  id                String   @id @default(uuid())
  orderId           String
  order             ServiceOrder @relation(fields: [orderId], references: [id])
  provider          String   @default("MERCADO_PAGO")
  providerPaymentId String?
  status            String   @default("PENDING")
  amount            Float    @default(0)
  commission        Float    @default(0)
  escrowStatus      String   @default("HELD")
  metadata          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  paidAt            DateTime?
  releasedAt        DateTime?
  refundedAt        DateTime?

  audits            PaymentAudit[]
  webhookEvents     PaymentWebhookEvent[]

  @@index([orderId])
  @@index([provider, providerPaymentId])
  @@index([status])
  @@index([escrowStatus])
}

model PaymentAudit {
  id          String   @id @default(uuid())
  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  orderId     String?
  provider    String?
  action      String
  status      String?
  amount      Float?
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([paymentId, createdAt])
  @@index([orderId, createdAt])
  @@index([action])
}

model PaymentWebhookEvent {
  id                String   @id @default(uuid())
  provider          String
  providerEventId   String
  providerPaymentId String?
  paymentId         String?
  payment           Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  signatureDigest   String?
  status            String   @default("PROCESSED")
  payload           String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  @@unique([provider, providerEventId])
  @@index([provider, providerPaymentId])
  @@index([paymentId])
  @@index([status])
}

model PaymentRecipient {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  provider            String   @default("PAGARME")
  providerRecipientId String
  status              String?
  metadata            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, provider])
  @@unique([provider, providerRecipientId])
  @@index([userId])
  @@index([provider])
}
