# =========================
# 🚀 AMBIENTE
# =========================
NODE_ENV=development
PORT=3000

# =========================
# 🗄️ BANCO DE DADOS
# =========================
# LOCAL (Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boraservico?schema=public"

# ⚠️ RAILWAY (produção)
# O Railway vai sobrescrever automaticamente isso quando fizer deploy

# =========================
# 🌐 CORS
# =========================
CORS_ORIGIN=*

# =========================
# ⚙️ PRISMA
# =========================
PRISMA_CLIENT_ENGINE_TYPE=binary