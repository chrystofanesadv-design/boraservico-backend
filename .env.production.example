NODE_ENV=production
PORT=3000

# Core obrigatorio
JWT_SECRET=replace_with_strong_secret_32_chars_min
REFRESH_TOKEN_SECRET=replace_with_different_strong_refresh_secret_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://usuario:senha@host:5432/boraservico
CORS_ORIGIN=https://seu-app.com,https://boraservico-backend.onrender.com
RENDER_EXTERNAL_URL=https://boraservico-backend.onrender.com
PUBLIC_API_URL=https://boraservico-backend.onrender.com

# Pagamentos: configure Mercado Pago ou Pagar.me. Para fallback, configure ambos.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
# Compatibilidade apenas para deploys antigos. Prefira MERCADO_PAGO_ACCESS_TOKEN.
MP_ACCESS_TOKEN=
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_RECIPIENT_ID=
PAGARME_PLATFORM_RECIPIENT_ID=
PAGARME_DEFAULT_RECIPIENT_ID=
PLATFORM_COMMISSION_RATE=0.10
PAYMENT_SUCCESS_URL=https://seu-app.com/pagamento/sucesso
PAYMENT_FAILURE_URL=https://seu-app.com/pagamento/falha
PAYMENT_PENDING_URL=https://seu-app.com/pagamento/pendente
MERCADO_PAGO_MARKETPLACE_FEE_ENABLED=false

# Google Maps producao
GOOGLE_MAPS_API_KEY=

# Firebase Admin / FCM
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# IA: configure Gemini ou OpenAI. Para fallback real, configure ambos.
AI_PROVIDER=auto
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OPENAI_API_KEY=

# Runtime
FCM_ENABLED=true
REALTIME_ENABLED=true

# Storage de provas. Use cloudflare-r2 para producao real privada.
PROOF_STORAGE_PROVIDER=cloudflare-r2
PROOF_STORAGE_DIR=
STORAGE_CDN_BASE_URL=
UPLOAD_PUBLIC_URL=
STORAGE_SIGNED_URL_TTL_SECONDS=900
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_ENDPOINT=
